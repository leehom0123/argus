# Argus runtime environment.
#
#   cp deploy/.env.example deploy/.env.production
#   # then edit deploy/.env.production: replace REPLACE_ME values
#
# This file is sourced by `docker compose up`. Treat it like a secret —
# it stays on the deploy host and is NEVER committed (covered by
# deploy/.gitignore). Keep this `.env.example` checked in, but never
# put real values here.
#
# Most fields are also configurable from the running app at
# Settings → Admin (DB-driven runtime config). The values here are the
# bootstrap fallbacks used the first time Argus starts; once you save
# a value in Settings → Admin, the DB row wins and these env vars are
# ignored on subsequent restarts.
#
# Tip: regenerate JWT + admin password with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"


# ── Core service ──────────────────────────────────────────────────────

# Public URL the UI is reachable at. Used to build email links + CORS.
# Include the scheme (https://) and any non-default port.
ARGUS_BASE_URL=https://argus.example.com

# 'prod' enforces 32+ byte JWT secret, requires SMTP for verification
# emails, and disables debug endpoints. Use 'dev' for local tinkering.
ARGUS_ENV=prod

# Standard Python log level: debug | info | warning | error
ARGUS_LOG_LEVEL=info

# Number of uvicorn workers. Rough rule: 2 × CPU cores. Single-host
# deployments default to 4. Increase for higher event-ingest throughput.
ARGUS_WORKERS=4


# ── Auth / sessions ───────────────────────────────────────────────────

# JWT signing secret. MUST be >= 32 bytes when ARGUS_ENV=prod.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
ARGUS_JWT_SECRET=REPLACE_ME

# CRITICAL: Fernet key for encrypting `system_config` secret rows
# (OAuth client secret, SMTP password, etc). If unset, falls back to
# ARGUS_JWT_SECRET — meaning a JWT rotation invalidates every stored
# encrypted secret. Set this BEFORE saving any secret in Settings →
# Admin so JWT can be rotated independently.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
ARGUS_CONFIG_KEY=REPLACE_ME

# First-time admin password (created on initial DB migration).
# Forgotten? Reset by editing the user row directly in the DB.
ARGUS_INITIAL_ADMIN_PASSWORD=REPLACE_ME


# ── Database ──────────────────────────────────────────────────────────

# Async SQLAlchemy URL. Postgres is recommended for production.
#   postgresql+asyncpg://<user>:<password>@<host>:5432/<db>
# For a quick local trial without Postgres, use SQLite:
#   sqlite+aiosqlite:///./argus.db
ARGUS_DB_URL=postgresql+asyncpg://argus:REPLACE_ME@db.example.com:5432/argus

# Postgres SSL mode. Common values: disable | prefer | require | verify-full
# Default is 'disable' (suits same-network deploys). Use 'require' or
# stricter when crossing trust boundaries.
ARGUS_DB_SSL=disable

# Connection-pool tuning (Postgres only). Defaults are fine for small
# deployments; raise pool_size if you see 'too many clients' errors.
ARGUS_DB_POOL_SIZE=5
ARGUS_DB_MAX_OVERFLOW=10


# ── Retention policy ──────────────────────────────────────────────────
# Days before old data is hard-deleted. Set to 0 to disable a rule.
# Retention sweeps run hourly via the in-process scheduler.
# Each knob is also editable in Settings → Admin → Retention.

# Resource snapshots (CPU/GPU/RAM samples written every 30s).
# Volume here grows fastest; default 14 days = ~2 GB per active host.
ARGUS_RETENTION_SNAPSHOT_DAYS=14

# Log-line events streamed via the SDK log capture.
ARGUS_RETENTION_LOG_LINE_DAYS=30

# Per-epoch metric events (the loss-curve source).
ARGUS_RETENTION_JOB_EPOCH_DAYS=180

# Other miscellaneous events (heartbeats, batch_start/done, etc).
ARGUS_RETENTION_EVENT_OTHER_DAYS=180

# Demo project events (seeded on first start). Keep short — they are
# illustrative, not real history.
ARGUS_RETENTION_DEMO_DATA_DAYS=30


# ── CORS ──────────────────────────────────────────────────────────────
# Comma-separated extra origins. ARGUS_BASE_URL is auto-included; only
# add others (dev frontend, secondary domain, etc).
ARGUS_CORS_ORIGINS=https://argus.example.com,http://localhost:5173


# ── GitHub OAuth (optional, also configurable in Settings → Admin) ───
# Set ARGUS_GITHUB_OAUTH_ENABLED=true and provide client_id +
# client_secret to enable "Sign in with GitHub". Callback URL is
# ARGUS_BASE_URL + /api/auth/oauth/github/callback.

ARGUS_GITHUB_OAUTH_ENABLED=false
ARGUS_GITHUB_CLIENT_ID=
ARGUS_GITHUB_CLIENT_SECRET=


# ── Email (optional, also configurable in Settings → Admin) ──────────
# When SMTP is unset, verification + notification emails are dropped to
# stdout instead of sent. ARGUS_ENV=prod refuses to start without SMTP
# unless every email feature is also disabled.

ARGUS_SMTP_HOST=
ARGUS_SMTP_PORT=587
ARGUS_SMTP_USER=
ARGUS_SMTP_PASS=
ARGUS_SMTP_FROM=noreply@argus.example.com
# 'true' to wrap the SMTP connection in STARTTLS. Set 'false' for
# plaintext (e.g. local mailhog dev).
ARGUS_SMTP_USE_TLS=true
# Optional comma-separated allowlist of SMTP relay hosts. Empty = any.
ARGUS_SMTP_HOST_ALLOWLIST=


# ── Feishu webhook (optional) ─────────────────────────────────────────
# Set to a Feishu group robot webhook URL to receive job-failure alerts
# alongside email. Leave blank to disable. No DB-driven equivalent —
# this env is the only switch.
ARGUS_FEISHU_WEBHOOK=


# ── Artifact storage ──────────────────────────────────────────────────
# Where job output files (uploaded via POST /api/jobs/{id}/artifacts)
# are stored on the host. Bind-mount this path into the container.
ARGUS_ARTIFACT_DIR=/var/lib/argus/artifacts

# Per-file size cap in MB. Reject larger uploads at the API.
ARGUS_ARTIFACT_MAX_FILE_MB=50

# Per-job total cap in MB across all of its artifacts.
ARGUS_ARTIFACT_MAX_JOB_MB=500


# ── Multi-worker coordination ─────────────────────────────────────────
# Directory for inter-worker file locks (singleton tasks like the
# retention sweeper, JWT key rotator). Default /tmp; only override if
# /tmp is tmpfs you don't trust across worker restarts.
ARGUS_LOCK_DIR=/tmp
